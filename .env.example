# NEVA Network — server-side environment (copy to `.env`; never commit `.env`).
# These are read ONLY by the Node server (server/index.mjs via `pnpm server`).
# They are NEVER exposed to the frontend bundle — do NOT prefix with VITE_.

# NEVA Core Assistant (OpenAI). If unset, NEVA Core runs OFFLINE with deterministic fallback hints.
OPENAI_API_KEY=

# Optional — OpenAI model for NEVA Core (default: gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Optional — NEVA Core request timeout in ms (default: 9000).
OPENAI_TIMEOUT_MS=9000

# Optional — waitlist/API server port (default: 8787).
PORT=8787
